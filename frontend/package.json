{
  "name": "frontend",
  "author": "Your Name",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=web",
    "dev:agents": "turbo dev --filter=agents",
    "dev:full": "concurrently \"turbo dev --filter=web\" \"turbo dev --filter=agents\"",
    "build": "turbo build",
    "test:web": "npm run test --workspace=web",
    "turbo:command": "turbo",
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tsconfig/recommended": "^1.0.8",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "latest",
    "typescript": "^5"
  },
  "packageManager": "npm@11.2.1",
  "overrides": {
    "@langchain/core": "^0.3.42"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "next-auth": "^5.0.0-beta.30"
  }
}
